# Backend config
TRANSLATOR_PROVIDER=deeplx
DEEPLX_ENDPOINT=https://api.deeplx.org/translate
DEEPLX_TIMEOUT=10

# Fallback config
TRANSLATOR_FALLBACK_ENABLED=true
TRANSLATOR_FALLBACK_ORDER=["google", "baidu"]

# Optional: Google
GOOGLE_API_KEY=

# Optional: Baidu
BAIDU_APP_ID=
BAIDU_SECRET_KEY=

# Optional: Youdao
YOUDAO_APP_KEY=
YOUDAO_SECRET_KEY=

# Whisper
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu

# WebSocket
WS_HEARTBEAT_INTERVAL=30
WS_MAX_CONNECTIONS=100
